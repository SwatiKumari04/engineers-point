# Copy this file to `.env` and adjust as needed.
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_ID=admin@nitjsr

# Email delivery for student login passwords.
# Leave both BREVO_API_KEY and SMTP_HOST empty for dev mode: passwords are
# returned in the API response and printed to the server console.

# Production (Render): use Brevo's HTTP API. Render's free tier blocks
# outbound SMTP ports (25/465/587), so mail must go over HTTPS.
# BREVO_API_KEY: Brevo > Settings > SMTP & API > API keys.
# BREVO_SENDER: an address verified under Brevo > Senders.
BREVO_API_KEY=
BREVO_SENDER=

# Local alternative: plain SMTP. For Gmail: SMTP_HOST=smtp.gmail.com,
# SMTP_USER=your address, SMTP_PASS=an app password
# (Google Account > Security > App passwords).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
